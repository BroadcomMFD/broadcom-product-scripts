* WAIT#2 input for the Table Tool step during Cast
  If $row# = 0 then $SkipRow = 'Y'
  ReportingDSN = ReportingPFX || '.#3'
* LONGEST  wait for the SonarQube Analysis to finish
  wait2 = max(wait2,10)
  wait3 = WAITFILE(ReportingDSN 55 wait2)
  say "ReportingDSN " ReportingDSN "is returned after" wait3 "waits"
  if wait3 = 0 then, +
     Do; Say 'WAIT#3 -#3 is lost'; Exit(12); end
  cmd = "ALLOC DD(STATUS3) DA("ReportingDSN") OLD REUSE "
  CALL BPXWDYN  cmd
  MODEL = 'STATUS3'
