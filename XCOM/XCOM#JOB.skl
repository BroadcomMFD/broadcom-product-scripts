//*-------------------------------------------------------------------
//XCOM#JOB EXEC PGM=XCOMJOB,   <- Exec SonarQube Analysis  XCOM#JOB
//     PARM=('TYPE=EXECUTE'),COND=(4,LT)
//STEPLIB  DD  DISP=SHR,
//             DSN=Your/XCOM/hlq.CBXGLOAD      * XCOM LOAD MODULES
//         DD  DISP=SHR,
//             DSN=CEE.SCEERUN                   * IBM LE RUNTIME
//XCOMCNTL DD  DISP=SHR,
//             DSN=your.XCOM.SVW.CBXGPARM       * CONTROL LIBRARY
//CAOESTOP DD DUMMY
//SYSIN01  DD *                                            XCOM#JOB
TYPE=SEND
IPNAME=192.0.2.1
IPPORT=####
CKPT=0
FILEOPT=REPLACE
FILETYPE=JOB
LFILE=&SonarWorkfile(LINUX)
USERID=user2
PASSWORD=pwd2
//*--------------------------------------------------------XCOM#JOB---
